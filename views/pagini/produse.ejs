<!DOCTYPE html>
<html lang="ro">

<head>
    <meta name="keywords" content="instrumente muzicale, magazin muzica, 
                            chitara, pian, tobe, instrumente de suflat">
    <meta name="description"
        content="Magazin online specializat în instrumente muzicale pentru muzicieni amatori și profesioniști.">
    <link rel="stylesheet" href="/resurse/css/produse.css" type="text/css" />
    title>Magazin online de instrumente muzicale: SoundMaster - Produse</title>
    <%- include("../fragmente/head") %>
        <script type="text/javascript" src=/resurse/js/produse.js></script>
        <script type="text/javascript" src=/resurse/js/produse-cos.js></script>

</head>

<body>


    <%- include("../fragmente/header") %>

        <main>

            <label>Nume: <input type="text" id="inp-nume"></label>

            <div>
                Tip instrument:

                <p><label>Piane
                        <input id="i_rad1" name="gr_rad" value="piane" type="radio">
                    </label></p>

                <p><label>Chitare și basuri
                        <input id="i_rad2" name="gr_rad" value="chitare_si_basuri" type="radio">
                    </label></p>

                <p><label>Tobe
                        <input id="i_rad3" name="gr_rad" value="tobe" type="radio">
                    </label></p>

                <p><label>Instrumente cu coarde
                        <input id="i_rad4" name="gr_rad" value="instrumente_cu_coarde" type="radio">
                    </label></p>

                <p><label>Toate
                        <input id="i_rad5" checked name="gr_rad" value="toate" type="radio">
                    </label></p>
            </div>


            <label>
                Preț minim:
                <input type="range" id="inp-pret" value="0" min="0" max="50000">
                <span id="infoRange">(0)</span>
            </label>


            <label>
                Select simplu:
                <select id="inp-categorie">
                    <option id="sel-toate" selected value="toate">toate</option>
                    <% for (let opt of locals.optiuni) { %>
                        <option value="<%- opt.unnest %>"><%- opt.unnest %></option>
                        <% } %>
                </select>
            </label>


            <p>
                <button class="c1 c2 c3" id="filtrare">Filtrează</button>

                <button id="resetare">Resetează</button><br />

                <button id="sortCrescNume">Sortează crescător după preț și nume</button>

                <button id="sortDescrescNume">Sortează descrescător după preț și nume</button>
            </p>


            <p id="p-suma">
                Apăsați Alt+"c" pentru suma prețurilor instrumentelor afișate.
            </p>


            <section id="produse">

                <h2>Instrumente</h2>

                <div class="grid-produse">

                    <% for (let prod of locals.produse) { %>
                        <article class="produs">

                            <h3 class="nume">
                                Nume:
                                <a href="/produs/<%- prod.id %>">
                                    <span class="val-nume"><%- prod.nume %></span>
                                </a>
                            </h3>

                            <div class="info-prod">

                                <p class="pret">
                                    Preț: <span class="val-pret"><%- prod.pret %></span>
                                </p>

                                <p class="greutate">
                                    Greutate: <span class="val-greutate"><%- prod.greutate %> g</span>
                                </p>

                                <p class="nr_componente">
                                    Componente: <span class="val-nr"><%- prod.nr_componente %></span>
                                </p>

                            </div>


                            <p class="categorie">
                                Utilizare:
                                <span class="val-categorie"><%- prod.categorie %></span>
                            </p>


                            <p class="tip_produs">
                                Tip instrument:
                                <span class="val-tip"><%- prod.tip_produs %></span>
                            </p>


                            <p class="materiale">
                                Materiale:
                                <span class="val-materiale"><%- prod.materiale %></span>
                            </p>


                            <p class="electric">
                                Electric:
                                <span class="val-electric"><%- prod.este_electric %></span>
                            </p>


                            <figure>
                                <a href="/produs/<%- prod.id %>">
                                    <img src="/resurse/imagini/produse/<%- prod.imagine %>"
                                        style="width:50%;height:auto;" alt="[imagine <%- prod.nume %>]" />
                                </a>
                            </figure>


                            <label class="selecteaza-cos">
                                Selectează:<br />
                                <input type="checkbox" class="select-cos" value="<%- prod.id %>" autocomplete="off">
                            </label>

                        </article>
                        <% } %>

                </div>

            </section>

        </main>

        <%- include("../fragmente/footer") %>
</body>

</html>