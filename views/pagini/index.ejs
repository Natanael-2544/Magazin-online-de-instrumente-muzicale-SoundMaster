                                <% for (let i=0; i < imagini.length; i++) { let img=imagini[i]; %>
                                    <figure>
                                        <img src="<%= img.fisier %>" alt="<%= img.titlu || 'Imagine galerie' %>">

                                        <figcaption>
                                            <%= img.titlu %>
                                        </figcaption>
                                    </figure>
                                    <% } %>
                                        <% } else { %>
                                            <p>Nu sunt imagini disponibile pentru galerie.</p>
                                            <% } %>
                        </div>
                    </div>


